# ============================================================
# Dependencies — must be rebuilt per platform (Linux vs Windows)
# ============================================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============================================================
# Next.js build output — must be rebuilt per platform
# ============================================================
.next/
/out/
/build

# ============================================================
# SQLite database — never commit real data
# ============================================================
data/*.db
data/*.db-shm
data/*.db-wal
data/backups/

# Keep the data/ folder itself in the repo (via .gitkeep)
!data/.gitkeep

# ============================================================
# Environment / secrets
# ============================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ============================================================
# TypeScript cache
# ============================================================
*.tsbuildinfo
next-env.d.ts

# ============================================================
# OS junk
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Logs
# ============================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ============================================================
# Editor / IDE
# ============================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo

# ============================================================
# Misc
# ============================================================
*.pem
.vercel
/coverage
